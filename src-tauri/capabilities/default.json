{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.fisioacces.app",
  "capabilities": [
    {
      "identifier": "default",
      "description": "Default capabilities for the app",
      "windows": ["main"],
      "permissions": [
        "core:default",
        "shell:allow-open",
        "dialog:default",
        "dialog:allow-save",
        "fs:default",
        "fs:allow-write-text-file",
        "fs:allow-write-file"
      ]
    }
  ]
}
